---
import { getRelatedPosts, getBlogPostPath, getTagColor, type BlogEntry } from "../lib/blog";

interface Props {
  entry: BlogEntry;
  isEnglish: boolean;
}

const { entry, isEnglish } = Astro.props;
const relatedPosts = await getRelatedPosts(entry, 3);

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat(isEnglish ? "en-US" : "es-ES", {
    year: "numeric",
    month: "short",
    day: "numeric",
  }).format(date);
---

{relatedPosts.length > 0 && (
  <section class="mt-14 mb-2" aria-label={isEnglish ? "Related articles" : "Artículos relacionados"}>
    <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-6 flex items-center gap-2">
      <svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"></path>
      </svg>
      {isEnglish ? "Related articles" : "Artículos relacionados"}
    </h2>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {relatedPosts.map((post) => (
        <a
          href={getBlogPostPath(post)}
          class="group block rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden hover:border-blue-300 dark:hover:border-blue-700 transition-colors bg-white dark:bg-gray-800/50"
        >
          {post.data.image?.url && (
            <div class="aspect-video overflow-hidden">
              <img
                src={post.data.image.url}
                alt={post.data.image.alt || post.data.title}
                width="400"
                height="225"
                loading="lazy"
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
              />
            </div>
          )}
          <div class="p-4">
            <time datetime={post.data.publishDate.toISOString()} class="text-xs text-gray-500 dark:text-gray-400">
              {formatDate(post.data.publishDate)}
            </time>
            <h3 class="mt-1 text-sm font-semibold text-gray-900 dark:text-white leading-snug group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors line-clamp-2">
              {post.data.title}
            </h3>
            {post.data.tags && post.data.tags.length > 0 && (
              <div class="flex flex-wrap gap-1.5 mt-2.5">
                {post.data.tags.slice(0, 3).map((tag) => (
                  <span class={`px-2 py-0.5 text-[10px] font-medium rounded-full border ${getTagColor(tag)}`}>{tag}</span>
                ))}
              </div>
            )}
          </div>
        </a>
      ))}
    </div>
  </section>
)}

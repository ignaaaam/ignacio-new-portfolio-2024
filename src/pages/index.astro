---
import Layout from "../layouts/Layout.astro";
import Badge from "../components/Badge.astro";
import SectionContainer from "../components/SectionContainer.astro";
import FullSectionContainer from "../components/FullSectionContainer.astro";
import LinkedinIcon from "../components/icons/LinkedinIcon.astro";
import GithubIcon from "../components/icons/GithubIcon.astro";
import BriefCaseIcon from "../components/icons/BriefCaseIcon.astro";
import MailIcon from "../components/icons/MailIcon.astro";
import BehanceIcon from "../components/icons/BehanceIcon.astro";
import StackOverflowIcon from "../components/icons/StackOverflowIcon.astro";
import CodeIcon from "../components/icons/CodeIcon.astro";
import LearningIcon from "../components/icons/LearningIcon.astro";
import CertificationIcon from "../components/icons/CertificationIcon.astro";
import CVDownloadButton from "../components/CVDownloadButton.astro";
import TechMarquee from "../components/TechMarquee.astro";

import PHPIcon from "../components/icons/PHPIcon.astro";
import LaravelIcon from "../components/icons/LaravelIcon.astro";
import VueIcon from "../components/icons/VueIcon.astro";
import JavascriptIcon from "../components/icons/JavascriptIcon.astro";
import TailwindIcon from "../components/icons/TailwindIcon.astro";
import AstroIcon from "../components/icons/AstroIcon.astro";
import ThunderIcon from "../components/icons/ThunderIcon.astro";

import Experience from "../components/Experience.astro";
import Certification from "../components/Certification.astro";
import Studies from "../components/Studies.astro";
import Projects from "../components/Projects.astro";
import ContactForm from "../components/ContactForm.astro";
import SkillsCloud from "../components/SkillsCloud.astro";
import FAQSection from "../components/FAQSection.astro";
---

<Layout
  title="Ignacio Amat | Desarrollador PHP Laravel Full Stack · Remoto"
  description="Desarrollador full stack PHP Laravel en remoto. +5 años creando aplicaciones web con Vue.js y MySQL. Código limpio, arquitectura escalable. Disponible ahora."
  pageType="profile"
>
  <main>
    <SectionContainer class="hero-section py-10 md:py-16 lg:py-20 md:min-h-[calc(100svh-4.5rem)] flex flex-col justify-center relative">
      <div class="max-w-3xl mx-auto text-center hero-content">
        <!-- Availability Badge -->
        <div class="flex items-center justify-center mb-4 md:mb-5">
          <Badge class="bg-green-100 dark:bg-green-900/50 text-green-800 dark:text-green-300">
            <span class="relative z-10 flex items-center gap-2">
              <span class="relative flex h-2 w-2" aria-hidden="true">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-500 opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-green-600"></span>
              </span>
              Abierto a nuevas oportunidades
            </span>
          </Badge>
        </div>

        <!-- H1 con keywords SEO en segunda línea -->
        <h1 class="text-3xl md:text-5xl lg:text-6xl font-bold text-gray-900 dark:text-white mb-2 md:mb-3 leading-tight animate-fade-in">
          Hola, soy <span class="bg-gradient-to-r from-blue-600 via-indigo-600 to-purple-600 bg-clip-text text-transparent animate-gradient">Ignacio</span>
          <span class="block text-2xl md:text-4xl lg:text-5xl mt-1 font-bold text-gray-700 dark:text-gray-200">
            Desarrollador Full Stack · PHP · Laravel · Vue.js
          </span>
        </h1>

        <!-- Descripción corta e impactante -->
        <p class="text-base md:text-lg text-gray-600 dark:text-gray-300 mb-5 md:mb-6 leading-relaxed max-w-2xl mx-auto">
          Más de 5 años construyendo aplicaciones web con PHP, Laravel y Vue.js para equipos remotos.
          Entrego código limpio, arquitectura escalable y producto real.
        </p>

        <!-- Stats inline (sin grid) -->
        <div class="flex flex-wrap justify-center items-center gap-x-3 gap-y-1 text-sm text-gray-500 dark:text-gray-400 mb-6 md:mb-7">
          <span class="font-semibold text-gray-800 dark:text-gray-200">+5 años de experiencia</span>
          <span aria-hidden="true" class="text-gray-300 dark:text-gray-600">·</span>
          <span class="font-semibold text-gray-800 dark:text-gray-200">10+ empresas</span>
          <span aria-hidden="true" class="text-gray-300 dark:text-gray-600">·</span>
          <span class="font-semibold text-gray-800 dark:text-gray-200">Entrega Full Stack E2E</span>
          <span aria-hidden="true" class="text-gray-300 dark:text-gray-600">·</span>
          <span class="font-semibold text-gray-800 dark:text-gray-200">Respuesta en 24h</span>
        </div>

        <!-- 2 CTAs: Contact (primario) + CV (secundario) -->
        <div class="hero-cta flex flex-col sm:flex-row gap-3 justify-center items-center mb-6 md:mb-7">
          <a
            href="#contact"
            class="group w-full sm:w-auto px-8 py-3.5 md:py-4 text-base md:text-lg font-bold text-white bg-gradient-to-r from-indigo-600 to-purple-700 rounded-xl shadow-lg hover:from-indigo-700 hover:to-purple-800 transition-all duration-300 transform hover:scale-105 hover:shadow-xl hover:shadow-purple-500/25 flex items-center justify-center gap-2 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-purple-500 focus-visible:ring-offset-2"
          >
            Hablemos
            <svg
              class="w-4 h-4 group-hover:translate-x-1 transition-transform"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
            </svg>
          </a>
          <div class="hero-cv-btn w-full sm:w-auto">
            <CVDownloadButton isEnglish={false} variant="cta">
              Descargar CV
            </CVDownloadButton>
          </div>
        </div>

        <!-- Social icons compactos (sin etiquetas) -->
        <nav aria-label="Perfiles sociales" class="flex items-center justify-center gap-3">
          <a
            href="https://www.linkedin.com/in/ignacio-amat-urbina-789244223"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
            class="w-9 h-9 flex items-center justify-center rounded-full border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 hover:border-blue-300 dark:hover:border-blue-600 transition-all duration-200 hover:shadow-sm"
          >
            <LinkedinIcon class="size-4" />
          </a>
          <a
            href="https://www.github.com/ignaaaam"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub"
            class="w-9 h-9 flex items-center justify-center rounded-full border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white hover:border-gray-400 dark:hover:border-gray-500 transition-all duration-200 hover:shadow-sm"
          >
            <GithubIcon class="size-4" />
          </a>
          <a
            href="https://www.behance.net/ignathedev"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Behance"
            class="w-9 h-9 flex items-center justify-center rounded-full border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 text-gray-600 dark:text-gray-400 hover:text-blue-500 dark:hover:text-blue-300 hover:border-blue-300 dark:hover:border-blue-600 transition-all duration-200 hover:shadow-sm"
          >
            <BehanceIcon class="size-4" />
          </a>
          <a
            href="https://stackoverflow.com/users/13370846/ignacio-amat-urbina"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Stack Overflow"
            class="w-9 h-9 flex items-center justify-center rounded-full border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 text-gray-600 dark:text-gray-400 hover:text-orange-500 dark:hover:text-orange-400 hover:border-orange-300 dark:hover:border-orange-600 transition-all duration-200 hover:shadow-sm"
          >
            <StackOverflowIcon class="size-4" />
          </a>
        </nav>

      </div>
    </SectionContainer>

    <!-- Marquee de tecnologías entre hero y servicios -->
    <TechMarquee isEnglish={false} />

    <!-- Services section -->
    <SectionContainer
      id="services"
      class="pt-12 md:pt-16 pb-20 md:pb-28"
    >
      <div class="text-center mb-12">
        <h2 class="text-4xl md:text-5xl font-bold mb-4 text-gray-900 dark:text-white">Mis Servicios de Desarrollo Web</h2>
        <p class="text-lg text-gray-600 dark:text-gray-300 max-w-2xl mx-auto leading-relaxed">Lo que aporto a tu equipo con experiencia real en producción con PHP, Laravel y Vue.js.</p>
      </div>

      <!-- Main services grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-16">
        <!-- Desarrollo Web Integral -->
        <div class="bg-white dark:bg-gray-800 rounded-2xl p-8 shadow-lg hover:shadow-xl transition-all duration-300 group border border-gray-200 dark:border-gray-700">
          <div class="w-16 h-16 bg-blue-100 dark:bg-blue-900/50 rounded-2xl flex items-center justify-center mb-6 group-hover:bg-blue-600 transition-colors duration-300">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-6 w-6 text-blue-600 dark:text-blue-400 group-hover:text-white"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              ></path>
            </svg>
          </div>
          <h3 class="text-2xl font-bold mb-4 text-gray-900 dark:text-white">Desarrollo Full Stack</h3>
          <p class="text-gray-600 dark:text-gray-300 text-sm leading-relaxed mb-4 flex-grow">
            Domino todo el stack: desde la arquitectura de base de datos y APIs REST con Laravel hasta interfaces reactivas con Vue.js. No necesitas explicarme cómo encajan las piezas — ya lo he hecho en producción.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="bg-blue-50 dark:bg-blue-900/50 text-blue-700 dark:text-blue-300 px-3 py-1 rounded-lg text-sm font-medium flex items-center gap-1">
              <PHPIcon class="w-4 h-4" />
              PHP
            </span>
            <span class="bg-red-50 dark:bg-red-900/50 text-red-700 dark:text-red-300 px-3 py-1 rounded-lg text-sm font-medium flex items-center gap-1">
              <LaravelIcon class="w-4 h-4" />
              Laravel
            </span>
            <span class="bg-sky-50 dark:bg-sky-900/50 text-sky-700 dark:text-sky-300 px-3 py-1 rounded-lg text-sm font-medium flex items-center gap-1">
              <AstroIcon class="w-4 h-4" />
              Astro
            </span>
            <span class="bg-green-50 dark:bg-green-900/50 text-green-700 dark:text-green-300 px-3 py-1 rounded-lg text-sm font-medium flex items-center gap-1">
              <VueIcon class="w-4 h-4" />
              Vue.js
            </span>
          </div>
        </div>

        <!-- Back-End Robusto -->
        <div class="bg-white dark:bg-gray-800 rounded-2xl p-8 shadow-lg hover:shadow-xl transition-all duration-300 group border border-gray-200 dark:border-gray-700">
          <div class="w-16 h-16 bg-green-100 dark:bg-green-900/50 rounded-2xl flex items-center justify-center mb-6 group-hover:bg-green-600 transition-colors duration-300">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-6 w-6 text-green-600 dark:text-green-400 group-hover:text-white"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
              ></path>
            </svg>
          </div>
          <h3 class="text-2xl font-bold mb-4 text-gray-900 dark:text-white">Back-End Sólido</h3>
          <p class="text-gray-600 dark:text-gray-300 text-sm leading-relaxed mb-4 flex-grow">
            Código limpio, testeable y mantenible. Construyo back-ends con PHP y Laravel que escalan con tu negocio: migraciones, colas, caché, autenticación y APIs que otros desarrolladores disfrutan consumir.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="bg-blue-50 dark:bg-blue-900/50 text-blue-700 dark:text-blue-300 px-3 py-1 rounded-lg text-sm font-medium flex items-center gap-1">
              <PHPIcon class="w-4 h-4" />
              PHP
            </span>
            <span class="bg-red-50 dark:bg-red-900/50 text-red-700 dark:text-red-300 px-3 py-1 rounded-lg text-sm font-medium flex items-center gap-1">
              <LaravelIcon class="w-4 h-4" />
              Laravel
            </span>
            <span class="bg-cyan-50 dark:bg-cyan-900/50 text-cyan-700 dark:text-cyan-300 px-3 py-1 rounded-lg text-sm font-medium flex items-center gap-1"> MySQL </span>
            <span class="bg-purple-50 dark:bg-purple-900/50 text-purple-700 dark:text-purple-300 px-3 py-1 rounded-lg text-sm font-medium flex items-center gap-1"> API REST </span>
          </div>
        </div>

        <!-- Interfaces Modernas -->
        <div class="bg-white dark:bg-gray-800 rounded-2xl p-8 shadow-lg hover:shadow-xl transition-all duration-300 group border border-gray-200 dark:border-gray-700">
          <div class="w-16 h-16 bg-purple-100 dark:bg-purple-900/50 rounded-2xl flex items-center justify-center mb-6 group-hover:bg-purple-600 transition-colors duration-300">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-6 w-6 text-purple-600 dark:text-purple-400 group-hover:text-white"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"
              ></path>
            </svg>
          </div>
          <h3 class="text-2xl font-bold mb-4 text-gray-900 dark:text-white">Front-End Vue.js con Criterio</h3>
          <p class="text-gray-600 dark:text-gray-300 text-sm leading-relaxed mb-4 flex-grow">
            Interfaces que no solo se ven bien — funcionan bien. Vue.js, JavaScript moderno y TailwindCSS para crear experiencias de usuario rápidas, accesibles y consistentes en cualquier dispositivo.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="bg-green-50 dark:bg-green-900/50 text-green-700 dark:text-green-300 px-3 py-1 rounded-lg text-sm font-medium flex items-center gap-1">
              <VueIcon class="w-4 h-4" />
              Vue.js
            </span>
            <span class="bg-yellow-50 dark:bg-yellow-900/50 text-yellow-700 dark:text-yellow-300 px-3 py-1 rounded-lg text-sm font-medium flex items-center gap-1">
              <JavascriptIcon class="w-4 h-4" />
              JavaScript
              <ThunderIcon class="w-3 h-3 text-yellow-500" />
            </span>
            <span class="bg-sky-50 dark:bg-sky-900/50 text-sky-700 dark:text-sky-300 px-3 py-1 rounded-lg text-sm font-medium flex items-center gap-1">
              <TailwindIcon class="w-4 h-4" />
              TailwindCSS
            </span>
          </div>
        </div>
      </div>

      <!-- Link sutil a proyectos -->
      <div class="text-center">
        <a
          href="#projects"
          class="inline-flex items-center gap-1.5 text-sm font-medium text-gray-500 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors duration-200 group"
        >
          Ver proyectos
          <svg class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </a>
      </div>
    </SectionContainer>
  </main>

  <SectionContainer
    id="expertise"
    class="py-20 md:py-28"
  >
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold mb-6 text-gray-900 dark:text-white">Tecnologías</h2>
      <p class="text-xl text-gray-600 dark:text-gray-300 max-w-3xl mx-auto leading-relaxed">Domino las tecnologías más demandadas del mercado para crear soluciones web robustas y escalables</p>
    </div>
    <SkillsCloud lang="es" />
  </SectionContainer>

  <FullSectionContainer
    id="brands"
    class="relative py-20 bg-gradient-to-r from-indigo-600 via-blue-600 to-purple-700 dark:from-indigo-800 dark:via-blue-800 dark:to-purple-900"
  >
    <div class="max-w-5xl mx-auto text-center">
      <h2 class="mb-4 text-4xl lg:text-5xl font-bold text-white">Experiencia en productos reales y equipos exigentes</h2>
      <p class="text-xl text-blue-100 dark:text-blue-200 max-w-3xl mx-auto mb-10">He trabajado en proyectos con alto volumen de usuarios, plataformas internas y producto digital con foco en rendimiento, estabilidad y crecimiento.</p>

      <div class="flex flex-wrap justify-center gap-3 mb-10">
        <span class="px-4 py-2 rounded-full bg-white/15 text-white text-sm md:text-base font-semibold border border-white/20">SaaS B2B</span>
        <span class="px-4 py-2 rounded-full bg-white/15 text-white text-sm md:text-base font-semibold border border-white/20">E-commerce</span>
        <span class="px-4 py-2 rounded-full bg-white/15 text-white text-sm md:text-base font-semibold border border-white/20">Plataformas internas</span>
        <span class="px-4 py-2 rounded-full bg-white/15 text-white text-sm md:text-base font-semibold border border-white/20">Sitios corporativos</span>
        <span class="px-4 py-2 rounded-full bg-white/15 text-white text-sm md:text-base font-semibold border border-white/20">Automatización de procesos</span>
        <span class="px-4 py-2 rounded-full bg-white/15 text-white text-sm md:text-base font-semibold border border-white/20">Optimización de rendimiento</span>
      </div>

      <a
        href="#experience"
        class="inline-block px-8 py-4 text-lg font-bold text-indigo-700 bg-white rounded-lg hover:bg-gray-50 transition-all duration-300 transform hover:scale-105 shadow-xl"
      >
        Ver mi experiencia completa
      </a>
    </div>
  </FullSectionContainer>
  <div class="w-full bg-gray-50 dark:bg-gray-900">
    <SectionContainer
      id="experience"
      class="py-20 md:py-28"
    >
      <div class="text-center mb-16">
        <h2 class="flex items-center justify-center mb-6 text-4xl md:text-5xl font-bold gap-x-4 text-gray-900 dark:text-white">
          <BriefCaseIcon class="size-12" />
          Experiencia Laboral
        </h2>
        <p class="text-xl text-gray-600 dark:text-gray-300 max-w-3xl mx-auto leading-relaxed">+5 años desarrollando soluciones web innovadoras para empresas y startups</p>
      </div>
      <Experience />
    </SectionContainer>
  </div>

  <SectionContainer
    id="academics"
    class="py-20 md:py-28"
  >
    <div class="text-center mb-16">
      <h2 class="flex items-center justify-center mb-6 text-4xl md:text-5xl font-bold gap-x-4 text-gray-900 dark:text-white">
        <LearningIcon class="size-12" />
        Formación Académica
      </h2>
      <p class="text-xl text-gray-600 dark:text-gray-300 max-w-3xl mx-auto leading-relaxed">Formación continua en las últimas tecnologías web y mejores prácticas</p>
    </div>
    <Studies />
  </SectionContainer>

  <div class="w-full bg-gray-50 dark:bg-gray-900">
    <SectionContainer
      id="certifications"
      class="py-20 md:py-28"
    >
      <div class="text-center mb-16">
        <h2 class="flex items-center justify-center mb-6 text-4xl md:text-5xl font-bold gap-x-4 text-gray-900 dark:text-white">
          <CertificationIcon class="size-12" />
          Certificaciones
        </h2>
        <p class="text-xl text-gray-600 dark:text-gray-300 max-w-3xl mx-auto leading-relaxed">Certificaciones profesionales que validan mi experiencia técnica</p>
      </div>
      <Certification />
    </SectionContainer>
  </div>

  <SectionContainer
    id="projects"
    class="py-20 md:py-28"
  >
    <div class="text-center mb-16">
      <h2 class="flex items-center justify-center mb-6 text-4xl md:text-5xl font-bold gap-x-4 text-gray-900 dark:text-white">
        <CodeIcon class="size-12" />
        Proyectos Destacados
      </h2>
      <p class="text-xl text-gray-600 dark:text-gray-300 max-w-3xl mx-auto leading-relaxed">Una selección de mis proyectos más relevantes y exitosos</p>
    </div>
    <Projects />
  </SectionContainer>

  <!-- FAQ Section -->
  <div class="w-full bg-gray-50 dark:bg-gray-900">
    <SectionContainer
      id="faq"
      class="py-20 md:py-28"
    >
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-bold mb-6 text-gray-900 dark:text-white">Preguntas Frecuentes</h2>
        <p class="text-xl text-gray-600 dark:text-gray-300 max-w-3xl mx-auto leading-relaxed">Respuestas a las preguntas más comunes de empresas que quieren contratarme</p>
      </div>
      <FAQSection />
    </SectionContainer>
  </div>

  <SectionContainer
    id="contact"
    class="py-20 md:py-28"
  >
    <div class="text-center mb-16">
      <h2 class="flex items-center justify-center mb-6 text-4xl md:text-5xl font-bold gap-x-4 text-gray-900 dark:text-white">
        <MailIcon class="size-12" />
        Contacto
      </h2>
      <p class="text-xl text-gray-600 dark:text-gray-300 max-w-3xl mx-auto leading-relaxed">¿Buscas un desarrollador full stack?</p>
      <p class="text-sm text-gray-500 dark:text-gray-400 mt-3">Hablemos sobre cómo puedo aportar valor a tu equipo.</p>
    </div>
    <ContactForm />
  </SectionContainer>
</Layout>

<style>
  main {
    color: #1f2937;
    font-size: 16px;
    line-height: 1.6;
  }

  .hero-section {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-left: 1rem;
    padding-right: 1rem;
    z-index: 1;
  }

  .hero-content {
    position: relative;
    z-index: 1;
  }

  .hero-cta a {
    min-height: 3rem;
  }

  @media (min-width: 768px) {
    .hero-cta a {
      min-height: 3.5rem;
    }
  }

  .hero-section::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 80px;
    background: linear-gradient(to bottom, transparent, rgba(249, 250, 251, 0.4));
    pointer-events: none;
    z-index: 0;
  }

  :global(.dark) .hero-section::after {
    background: linear-gradient(to bottom, transparent, rgba(17, 24, 39, 0.4));
  }

  /* Gradient text animation */
  @keyframes gradient {
    0%,
    100% {
      background-position: 0% 50%;
    }
